        knob.Position = UDim2.new(0,3,0.5,-8); Corner(knob, 8)
        return pill, knob
    end

    local function SetPill(pill, knob, on)
        TweenService:Create(pill, TweenInfo.new(0.16), {BackgroundColor3 = on and C.ACC2 or Color3.fromRGB(130,45,0)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.16), {
            Position = on and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8),
            BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(200,140,80),
        }):Play()
    end

    local function ToggleRow(panel, title, order, onToggle)
        local row = Frame(panel, C.SURFACE, UDim2.new(1,0,0,38))
        row.LayoutOrder = order; Corner(row, 8); Stroke(row, C.BORD, 1, 0.3)
        local lbl = Label(row, title, 10, C.TXT, Enum.Font.GothamBold)
        lbl.Size = UDim2.new(1,-60,1,0); lbl.Position = UDim2.new(0,12,0,0)
        local pill, knob = MakePill(row)
        local state = false
        pill.MouseButton1Click:Connect(function()
            state = not state; SetPill(pill, knob, state)
            if onToggle then onToggle(state) end
        end)
        row.MouseEnter:Connect(function() TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3=C.SURFACE2}):Play() end)
        row.MouseLeave:Connect(function() TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3=C.SURFACE}):Play() end)
        return row, pill, knob
    end

    ToggleRow(p, "Auto Magnet Gold", 1, function(on)
        MAIN_STATE.autoCollectDrops = on
        DoAutoCollect(on)
    end)
end

