local bubbleConn
local function StartFloat()
    local t = 0
    local base = Bubble.Position.Y.Scale
    bubbleConn = RunService.Heartbeat:Connect(function(dt)
        t = t + dt
        Bubble.Position = UDim2.new(
            Bubble.Position.X.Scale,
            Bubble.Position.X.Offset,
            base,
            -30 + math.sin(t*2)*8
        )
