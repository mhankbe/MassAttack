local Panels = {}
local ActiveTab = nil
local NavRefs = {}

local function NewPanel(tag)
    local p = Instance.new("ScrollingFrame", ContentArea)
    p.Name = tag
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.BorderSizePixel = 0
    p.ScrollBarThickness = 3
    p.ScrollBarImageColor3 = C.ACC
    p.CanvasSize = UDim2.new(0, 0, 0, 0)
    p.AutomaticCanvasSize = Enum.AutomaticSize.Y
    p.Visible = false
    local pad = Instance.new("UIPadding", p)
    pad.PaddingTop = UDim.new(0, 10)
    pad.PaddingBottom = UDim.new(0, 16)
    pad.PaddingLeft = UDim.new(0, 12)
    pad.PaddingRight = UDim.new(0, 12)
    local list = Instance.new("UIListLayout", p)
    list.Padding = UDim.new(0, 6)
    list.SortOrder = Enum.SortOrder.LayoutOrder
    Panels[tag] = p
    return p
end

local function SwitchTab(tag)
    for _, p in pairs(Panels) do p.Visible = false end
    if Panels[tag] then Panels[tag].Visible = true end
    ActiveTab = tag
    for _, r in pairs(NavRefs) do
        local on = (r.tag == tag)
        TweenService:Create(r.bg, TweenInfo.new(0.14), {
            BackgroundColor3       = on and C.SEL_BG or C.SIDEBAR,
            BackgroundTransparency = on and 0 or 1,
        }):Play()
        r.bar.BackgroundColor3 = on and C.ACC or C.SIDEBAR
        r.ico.TextColor3 = on and C.ACC2 or C.TXT3
        r.lbl.TextColor3 = on and C.TXT or C.TXT2
        r.lbl.Font = on and Enum.Font.GothamBold or Enum.Font.Gotham
        if on then
            Stroke(r.bg, C.SEL_BORD, 1, 0)
        else
            local s = r.bg:FindFirstChildOfClass("UIStroke")
            if s then s:Destroy() end
        end
    end
end

