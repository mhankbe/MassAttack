local function MakeWeaponSlotPopup(ddBtn, slotIndex)
    CloseActiveDD()
    local absPos  = ddBtn.AbsolutePosition
    local absSize = ddBtn.AbsoluteSize

    local list       = W_QUIRK_LIST_PER_SLOT[slotIndex]
    local ITEM_H     = 32          -- tinggi per item
    local SCROLL_MAX = _isSmallScreen and 170 or 200  -- max tinggi scroll area
    local HEADER_H   = 32
    local contentH   = #list * (ITEM_H + 2) + 10     -- total tinggi konten
    local scrollH    = math.min(contentH, SCROLL_MAX) -- tinggi area scroll yg terlihat
    local popupW     = absSize.X + 30
    local popupH     = HEADER_H + scrollH

    -- Popup container — ukuran fix, tidak pakai AutomaticSize
    local popup = Instance.new("Frame")
    popup.Parent              = DDLayer
    popup.BackgroundColor3    = C.DD_BG
    popup.BorderSizePixel     = 0
    popup.Size                = UDim2.new(0, popupW, 0, popupH)
    popup.Position            = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 3)
    popup.ZIndex              = 9999
    popup.ClipsDescendants    = true
    Corner(popup,8); Stroke(popup,C.BORD2,1,0.2)

    -- Header
    local popHeader=Frame(popup,Color3.fromRGB(90,30,0),UDim2.new(1,0,0,HEADER_H))
    popHeader.ZIndex=9999
    local countLbl=Label(popHeader,"0/"..W_MAX_PER_SLOT.." dipilih",10.5,C.ACC2,Enum.Font.GothamBold)
    countLbl.Size=UDim2.new(0.6,0,1,0); countLbl.Position=UDim2.new(0,8,0,0); countLbl.ZIndex=9999
    local clearBtn=Btn(popHeader,Color3.fromRGB(180,50,50),UDim2.new(0,50,0,20))
    clearBtn.Position=UDim2.new(1,-56,0.5,-10); Corner(clearBtn,5); clearBtn.ZIndex=9999
    local cLbl=Label(clearBtn,"Clear",10,Color3.fromRGB(255,255,255),Enum.Font.GothamBold,Enum.TextXAlignment.Center)
    cLbl.Size=UDim2.new(1,0,1,0); cLbl.ZIndex=9999

    -- ScrollingFrame — ukuran eksplisit, CanvasSize manual
    local scrollPop = Instance.new("ScrollingFrame")
    scrollPop.Parent               = popup
    scrollPop.BackgroundColor3     = C.DD_BG
    scrollPop.BorderSizePixel      = 0
    scrollPop.Position             = UDim2.new(0, 0, 0, HEADER_H)
    scrollPop.Size                 = UDim2.new(1, 0, 0, scrollH)
    scrollPop.CanvasSize           = UDim2.new(0, 0, 0, contentH)
    scrollPop.ScrollBarThickness   = 6
    scrollPop.ScrollBarImageColor3 = C.ACC
    scrollPop.ScrollingDirection   = Enum.ScrollingDirection.Y
    scrollPop.ElasticBehavior      = Enum.ElasticBehavior.Never
    scrollPop.ZIndex               = 9999
    Instance.new("UIListLayout", scrollPop).SortOrder = Enum.SortOrder.LayoutOrder
    local _sp = Instance.new("UIPadding", scrollPop)
    _sp.PaddingTop    = UDim.new(0,4)
    _sp.PaddingBottom = UDim.new(0,4)
    _sp.PaddingLeft   = UDim.new(0,4)
    _sp.PaddingRight  = UDim.new(0,8)

    local wRowRefs = {}

    for _,q in ipairs(list) do
        local qRow=Btn(scrollPop,C.DD_BG,UDim2.new(1,-8,0,28))
        qRow.ZIndex=9999; Corner(qRow,5)
        local tickBox=Frame(qRow,C.SEL_BG,UDim2.new(0,16,0,16))
        tickBox.Position=UDim2.new(0,6,0.5,-8); Corner(tickBox,3); tickBox.ZIndex=9999; Stroke(tickBox,C.BORD2,1,0.4)
        local tickMark=Label(tickBox,"✓",11,C.BLACK,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
        tickMark.Size=UDim2.new(1,0,1,0); tickMark.ZIndex=9999
        tickMark.Visible=(_wSlotTarget[slotIndex][q.id]==true)
        local qLbl=Label(qRow,"  "..q.name,11,_wSlotTarget[slotIndex][q.id] and C.ACC2 or C.TXT,Enum.Font.Gotham)
        qLbl.Size=UDim2.new(1,-30,1,0); qLbl.Position=UDim2.new(0,28,0,0); qLbl.ZIndex=9999
        if _wSlotTarget[slotIndex][q.id] then qRow.BackgroundColor3=Color3.fromRGB(140,52,0) end
        wRowRefs[q.id]={bg=qRow,tick=tickMark,lbl=qLbl}

        qRow.MouseButton1Click:Connect(function()
            if _wSlotTarget[slotIndex][q.id] then
                _wSlotTarget[slotIndex][q.id]=nil
            else
                local n=0; for _ in pairs(_wSlotTarget[slotIndex]) do n=n+1 end
                if n>=W_MAX_PER_SLOT then
                    countLbl.TextColor3=Color3.fromRGB(255,60,60)
                    countLbl.Text="MAX "..W_MAX_PER_SLOT.." tercapai!"
                    task.delay(1.2,function()
                        local n2=0; for _ in pairs(_wSlotTarget[slotIndex]) do n2=n2+1 end
                        countLbl.Text=n2.."/"..W_MAX_PER_SLOT.." dipilih"
                        countLbl.TextColor3=n2>=W_MAX_PER_SLOT and Color3.fromRGB(255,100,80) or C.ACC2
                    end)
                    return
                end
                _wSlotTarget[slotIndex][q.id]=true
            end
            for qid,ref in pairs(wRowRefs) do
                local sel=(_wSlotTarget[slotIndex][qid]==true)
                ref.bg.BackgroundColor3=sel and Color3.fromRGB(140,52,0) or C.DD_BG
                ref.tick.Visible=sel; ref.lbl.TextColor3=sel and C.ACC2 or C.TXT
            end
            local n=0; for _ in pairs(_wSlotTarget[slotIndex]) do n=n+1 end
            countLbl.Text=n.."/"..W_MAX_PER_SLOT.." dipilih"
            countLbl.TextColor3=n>=W_MAX_PER_SLOT and Color3.fromRGB(255,100,80) or C.ACC2
            RefreshWeaponSlotUI(slotIndex)
        end)
    end

    local n=0; for _ in pairs(_wSlotTarget[slotIndex]) do n=n+1 end
    countLbl.Text=n.."/"..W_MAX_PER_SLOT.." dipilih"
    clearBtn.MouseButton1Click:Connect(function()
        _wSlotTarget[slotIndex]={}
        for _,ref in pairs(wRowRefs) do ref.bg.BackgroundColor3=C.DD_BG; ref.tick.Visible=false; ref.lbl.TextColor3=C.TXT end
        countLbl.Text="0/"..W_MAX_PER_SLOT.." dipilih"; countLbl.TextColor3=C.ACC2
        RefreshWeaponSlotUI(slotIndex)
    end)

    DDLayer.Visible=true
    _activeDDClose=function() popup:Destroy(); DDLayer.Visible=false end
end

