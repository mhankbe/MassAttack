    task.spawn(function()
        while true do
            task.wait(1)
            local utc=os.time()
            local wib=utc+(7*3600)
            local h=math.floor(wib/3600)%24
            local m=math.floor(wib/60)%60
            local s=wib%60
            local wibStr=string.format("%02d:%02d:%02d",h,m,s)
            local durStr="00:00:00"
            if STATE.antiAfk and _antiAfkStart then
                local dur=os.time()-_antiAfkStart
                local dh=math.floor(dur/3600)
                local dm=math.floor(dur/60)%60
                local ds=dur%60
                durStr=string.format("%02d:%02d:%02d",dh,dm,ds)
            end
            pcall(function()
                afkTimeLbl.Text="WIB: "..wibStr.."  |  Aktif: "..durStr
                afkTimeLbl.TextColor3=STATE.antiAfk and C.ACC2 or C.TXT2
            end)
        end
