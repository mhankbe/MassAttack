-- =====================================================
-- QUIRK NAME SCANNER
-- Scan ReplicatedStorage untuk cari mapping ID → nama
-- quirk yang asli dari developer game.
-- Hasil print ke console, dan auto-patch QUIRK_LIST
-- jika ditemukan.
-- =====================================================
local function ScanQuirkNamesFromGame()
    local found = {}  -- [id] = name

    -- Helper: rekursif scan table Lua biasa
    local function ScanLuaTable(tbl, depth, path)
        if depth > 6 or type(tbl) ~= "table" then return end
        for k, v in pairs(tbl) do
            local p = path.."."..tostring(k)
            if type(v) == "table" then
                -- Cari pola {id=XXXXX, name="..."} atau {quirkId=..., quirkName=...}
                local id   = v.id or v.quirkId or v.quirk_id or v.QuirkId or v.drawId
                local name = v.name or v.quirkName or v.quirk_name or v.Name or v.QuirkName or v.title
                if type(id)=="number" and id>=99000 and id<=99999 and type(name)=="string" and #name>0 then
                    if not found[id] then
                        found[id] = name
                    end
                end
                -- Cari pola {[id] = "name"} langsung
                for ik, iv in pairs(v) do
                    if type(ik)=="number" and ik>=99000 and ik<=99999 and type(iv)=="string" and #iv>0 then
                        if not found[ik] then found[ik]=iv end
                    end
                end
                ScanLuaTable(v, depth+1, p)
            end
        end
    end

    -- Helper: scan Instance tree cari StringValue/ModuleScript/table attribute
    local function ScanInstance(obj, depth)
        if depth > 5 or not obj then return end
        pcall(function()
            -- Scan attribute
            for k,v in pairs(obj:GetAttributes()) do
                if type(v)=="string" then
                    -- Coba parse JSON-like atau cek apakah value adalah nama quirk
                    -- dengan key berupa angka di range quirk
                    local id = tonumber(k)
                    if id and id>=99000 and id<=99999 then
                        if not found[id] then found[id]=v end
                    end
                end
            end
            -- Scan children
            for _,child in ipairs(obj:GetChildren()) do
                if not obj then break end
                -- ModuleScript: coba require
                if child.ClassName == "ModuleScript" then
                    local ok, data = pcall(require, child)
                    if ok and type(data)=="table" then
                        ScanLuaTable(data, 0, child.Name)
                    end
                -- StringValue dengan nama yang mirip quirk
                elseif child.ClassName == "StringValue" or child.ClassName == "IntValue" then
                    local id = tonumber(child.Name)
                    if id and id>=99000 and id<=99999 and child.ClassName=="StringValue" then
                        if not found[id] then found[id]=child.Value end
                    end
                end
                ScanInstance(child, depth+1)
            end
        end)
    end

    -- Scan root-root yang paling mungkin punya quirk data
    local roots = {
        RS,
        RS:FindFirstChild("Data"),
        RS:FindFirstChild("GameData"),
        RS:FindFirstChild("Config"),
        RS:FindFirstChild("Configs"),
        RS:FindFirstChild("QuirkData"),
