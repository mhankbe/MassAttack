local function StartSlotLoop(slotIndex)
    -- Snapshot target saat loop mulai
    local targets = {}
    for id,_ in pairs(_slotTarget[slotIndex]) do
        targets[id] = true
    end
    local hasTarget = (next(targets) ~= nil)

    local targetStr = "apapun"
    if hasTarget then
        local names = {}
        for id,_ in pairs(targets) do
            table.insert(names, QUIRK_MAP[id] or tostring(id))
        end
        targetStr = table.concat(names, ", ")
    end

    print("[Roll S"..slotIndex.."] START | target: "..targetStr)

    LOOPS["roll"..slotIndex] = task.spawn(function()
        local count = 0
        while _rollRunning do
            count = count + 1

            -- Update status UI
            if _rerollStatusLbl then
                _rerollStatusLbl.Text = "⟳ Slot "..slotIndex.." | #"..count.." | "..targetStr
                _rerollStatusLbl.TextColor3 = Color3.fromRGB(255,200,100)
            end

            -- Invoke server
            local ok, result = pcall(function()
                return RE_RandomHeroQuirk:InvokeServer({
                    heroGuid = _rollHeroGuid,
                    drawId   = 920001,
                })
            end)

            if not ok then
                warn("[Roll S"..slotIndex.."] pcall error #"..count)
                task.wait(1)
            elseif type(result) == "table" then
                local gotId = result.quirkId
                local name  = QUIRK_MAP[gotId] or ("ID:"..tostring(gotId))
                print("[Roll S"..slotIndex.."] #"..count.." → "..name)

                -- Cek apakah target
                local hit = (not hasTarget) or (targets[gotId] == true)
                if hit then
                    StopAllRolls("✓ Slot "..slotIndex..": "..name.." (#"..count..")")
                    return
                end
                task.wait(0.15)
            else
                warn("[Roll S"..slotIndex.."] result bukan table: "..tostring(result))
                task.wait(0.5)
            end
        end
        print("[Roll S"..slotIndex.."] loop berhenti.")
    end)
end

