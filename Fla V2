            end
            countLbl.Text="0/"..MAX_PER_SLOT.." dipilih"
            countLbl.TextColor3=C.ACC2
            RefreshSlotUI(slotIndex)
        end)

        DDLayer.Visible=true

        local function Close()
            popup:Destroy()
            _activeScrollPop=nil; _activeRowRefs={}; _activeCountLbl=nil
            DDLayer.Visible=false; _activeDDClose=nil
            RefreshSlotUI(slotIndex)
        end
        _activeDDClose=Close
    end)

    return row
end

