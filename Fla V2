-- =====================================================
-- UUID VALIDATOR
-- Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
-- =====================================================
local UUID_PATTERN = "^%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x$"

local function IsValidUUID(s)
    return type(s)=="string" and #s==36 and s:match(UUID_PATTERN)~=nil
end

-- Deep scan table/payload cari semua UUID di dalamnya
local function ExtractUUIDs(val, depth, found)
    depth = depth or 0
    found = found or {}
    if depth > 5 then return found end
    local t = type(val)
    if t=="string" then
        if IsValidUUID(val) then found[val]=true end
    elseif t=="table" then
        for k,v in pairs(val) do
            -- Prioritas: key yang mengandung kata "guid"/"hero"
            if type(k)=="string" then
                local kl = k:lower()
                if (kl:find("guid") or kl:find("hero") or kl:find("id"))
                    and type(v)=="string" and IsValidUUID(v) then
                    found[v] = (kl:find("guid") or kl:find("hero")) and "priority" or true
                end
            end
            ExtractUUIDs(v, depth+1, found)
        end
    end
    return found
end

