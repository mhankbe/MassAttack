                            end
                        end
                    end
                end

                -- Parse RESPONSE untuk dapatkan nama asli quirk
                local res = rets[1]
                if type(res) == "table" then
                    local function ScanResponseForQuirks(tbl, depth, si)
                        if depth > 5 or type(tbl)~="table" then return end
