local function AddQuirkToSlot(slotIndex, quirkId, quirkName)
    if not slotIndex or not quirkId then return end
    local list = QUIRK_LIST_PER_SLOT[slotIndex]
    if not list then return end
    for _,q in ipairs(list) do
        if q.id == quirkId then
            if quirkName and not quirkName:find("^ID:") then q.name = quirkName end
            return
        end
    end
    table.insert(list, {id=quirkId, name=quirkName or ("ID:"..quirkId)})
    if not QUIRK_MAP[quirkId] then QUIRK_MAP[quirkId] = quirkName or ("ID:"..quirkId) end
end

local function SetupUniversalSpy()
    if _layer0Active then return end

    -- Cek apakah getrawmetatable tersedia (Delta/exploit env)
    if type(getrawmetatable) ~= "function" then
        warn("[ ASH ] getrawmetatable tidak tersedia di executor ini")
        if _captureStatusLbl then
            _captureStatusLbl.Text = "⚠ Executor tidak support hook — input manual"
            _captureStatusLbl.TextColor3 = Color3.fromRGB(255,80,80)
        end
        return
    end

    _layer0Active = true
    local ok, err = pcall(function()
        local mt    = getrawmetatable(game)
        local oldNC = mt.__namecall
        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args   = table.pack(...)

            if method == "InvokeServer" or method == "FireServer" then
                if self == RE_RandomHeroQuirk or self == RE_AutoHeroQuirk then
                    for i = 1, args.n do
                        local a = args[i]
                        if type(a) == "table" then
                            local g = a.heroGuid or a.HeroGuid or a.hero_guid
                            if g and IsValidUUID(tostring(g)) then
                                SetHeroGuid(tostring(g), "hook:"..tostring(self.Name))
                            end
                            local d = a.drawId or a.DrawId or a.draw_id
                            if type(d) == "number" then
                                local SLOT_HINTS = {
                                    {idx=1, default=920001},
                                    {idx=2, default=920002},
                                    {idx=3, default=920003},
                                }
                                local matched = false
                                for _,s in ipairs(SLOT_HINTS) do
                                    if _slotDrawId[s.idx] == d then matched = true; break end
                                end
                                if not matched then
                                    for _,s in ipairs(SLOT_HINTS) do
                                        if not _slotDrawIdCaptured[s.idx] then
                                            _slotDrawId[s.idx] = d
                                            _slotDrawIdCaptured[s.idx] = true
                                            print("[ ASH ✓ ] drawId Slot "..s.idx.." captured dari game → "..d)
                                            break
                                        end
                                    end
                                else
                                    for _,s in ipairs(SLOT_HINTS) do
                                        if _slotDrawId[s.idx] == d and not _slotDrawIdCaptured[s.idx] then
                                            _slotDrawIdCaptured[s.idx] = true
                                            print("[ ASH ✓ ] drawId Slot "..s.idx.." confirmed → "..d)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end

            -- Intercept RESPONSE dari InvokeServer untuk capture nama quirk asli
            local rets = table.pack(oldNC(self, table.unpack(args, 1, args.n)))
            if method == "InvokeServer"
            and (self == RE_RandomHeroQuirk or self == RE_AutoHeroQuirk) then
                -- Cari slotIndex dari drawId yang dikirim
                local sentDrawId = nil
                for i=1, args.n do
                    local a = args[i]
                    if type(a)=="table" then
                        sentDrawId = a.drawId or a.DrawId or a.draw_id
                    end
                end
                local slotIdx = nil
                if sentDrawId then
                    for si, did in ipairs(_slotDrawId) do
                        if did == sentDrawId then slotIdx = si; break end
                    end
                end

                -- Populate quirk dari field stopQuirkIds di REQUEST (berisi semua ID pool slot ini)
                -- lalu nama dari response
                for i=1, args.n do
                    local a = args[i]
                    if type(a)=="table" and type(a.stopQuirkIds)=="table" and slotIdx then
                        -- stopQuirkIds berisi semua ID quirk milik slot ini
                        -- nama akan kita isi dari response nanti, untuk sekarang register ID-nya
                        for _, qid in ipairs(a.stopQuirkIds) do
                            if type(qid)=="number" then
                                -- Tambahkan dengan nama sementara "ID:xxxxx" jika belum ada
                                if not QUIRK_MAP[qid] then
                                    AddQuirkToSlot(slotIdx, qid, "ID:"..qid)
                                end
                            end
                        end
                    end
                end

                -- Parse RESPONSE untuk dapatkan nama asli quirk
                local res = rets[1]
                if type(res) == "table" then
                    local function ScanResponseForQuirks(tbl, depth, si)
                        if depth > 5 or type(tbl)~="table" then return end
                        -- Pola {id=XXXXX, name="..."} atau {quirkId=..., quirkName=...}
                        local id   = tbl.quirkId or tbl.finalResultId or tbl.resultId
                                  or tbl.id or tbl.Id or tbl.quirk_id
                        local name = tbl.quirkName or tbl.name or tbl.quirk_name
                                  or tbl.Name or tbl.title or tbl.displayName
                        if type(id)=="number" and id>=90000 and id<=99999
                        and type(name)=="string" and #name>0 and not name:find("^ID:") then
                            local targetSlot = si
                            -- Kalau belum tahu slotnya, tebak dari ID
                            if not targetSlot then
                                for si2, list in ipairs(QUIRK_LIST_PER_SLOT) do
                                    for _, q in ipairs(list) do
                                        if q.id == id then targetSlot = si2; break end
                                    end
                                    if targetSlot then break end
                                end
                                if not targetSlot then targetSlot = 1 end
                            end
                            AddQuirkToSlot(targetSlot, id, name)
                        end
                        -- Scan array of quirks
                        for _, v in pairs(tbl) do
                            if type(v)=="table" then
                                ScanResponseForQuirks(v, depth+1, si)
                            end
                        end
                    end
                    ScanResponseForQuirks(res, 0, slotIdx)
                end
            end
            return table.unpack(rets, 1, rets.n)
        end)

        setreadonly(mt, true)
    end)

    if ok then
        print("[ ASH ] Layer 0 (targeted hook) aktif ✓")
        if _captureStatusLbl then
            _captureStatusLbl.Text = "⟳ Hook aktif — klik ReRoll 1x di game"
            _captureStatusLbl.TextColor3 = Color3.fromRGB(255,200,100)
        end
    else
        warn("[ ASH ] Layer 0 gagal: "..tostring(err))
        if _captureStatusLbl then
            _captureStatusLbl.Text = "⚠ Hook gagal — coba scan manual"
            _captureStatusLbl.TextColor3 = Color3.fromRGB(255,80,80)
        end
    end
end

