    for _, obj in ipairs(goldsFolder:GetChildren()) do
        local guid = nil
        pcall(function()
            guid = obj:GetAttribute("GUID")
        end)
        if guid and guid ~= "" and not _collectedGuids[guid] then
            table.insert(guids, guid)
        end
    end
    return guids
end

local function DoAutoCollect(on)
    if on then
        _collectedGuids   = {}
        _autoCollectLoop  = task.spawn(function()
            while MAIN_STATE.autoCollectDrops do
                local guids = GetAllDropGuids()

                for _, guid in ipairs(guids) do
                    if not MAIN_STATE.autoCollectDrops then break end

                    _collectedGuids[guid] = true

                    -- Collect item utama
                    pcall(function()
                        RE_CollectItem:InvokeServer(guid)
                    end)

                    -- Extra reward / bonus gold
                    pcall(function()
                        RE_ExtraReward:FireServer({
                            isSell = true,
                            guid   = guid,
                        })
                    end)

                    task.wait(0.05) -- jeda kecil antar item
                end

                task.wait(0.2) -- interval scan ulang workspace
            end
        end)
    else
        if _autoCollectLoop then
            pcall(function() task.cancel(_autoCollectLoop) end)
            _autoCollectLoop = nil
        end
        _collectedGuids = {}
    end
end

