    -- Quirk checklist
    for i, quirk in ipairs(QUIRK_LIST) do
        local checked = false
        local row = Btn(p, C.SURFACE, UDim2.new(1,0,0,32))
        row.LayoutOrder = 10+i; Corner(row,8); Stroke(row,C.BORD,1,0.5)

        -- Checkbox
        local box = Frame(row, C.SEL_BG, UDim2.new(0,18,0,18))
        box.Position=UDim2.new(0,8,0.5,-9); Corner(box,4)
        Stroke(box, C.BORD2, 1, 0.3)
        local tick = Label(box, "", 12, C.ACC2, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
        tick.Size=UDim2.new(1,0,1,0)

        -- Nama quirk
        local nameLbl = Label(row, quirk.name, 10, C.TXT, Enum.Font.Gotham)
        nameLbl.Size=UDim2.new(1,-36,1,0); nameLbl.Position=UDim2.new(0,34,0,0)

        local function SetChecked(v)
            checked = v
            _rollTargetIds[quirk.id] = v
            tick.Text = v and "✓" or ""
            TweenService:Create(box, TweenInfo.new(0.12), {
                BackgroundColor3 = v and C.ACC2 or C.SEL_BG
            }):Play()
            TweenService:Create(row, TweenInfo.new(0.12), {
                BackgroundColor3 = v and Color3.fromRGB(140,50,0) or C.SURFACE
            }):Play()
            tick.TextColor3 = v and C.BLACK or C.ACC2
        end

        row.MouseButton1Click:Connect(function() SetChecked(not checked) end)
        row.MouseEnter:Connect(function()
            if not checked then
                TweenService:Create(row,TweenInfo.new(0.1),{BackgroundColor3=C.SURFACE2}):Play()
            end
        end)
        row.MouseLeave:Connect(function()
            if not checked then
                TweenService:Create(row,TweenInfo.new(0.1),{BackgroundColor3=C.SURFACE}):Play()
            end
        end)
    end
end

