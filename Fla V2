    local statusLbl=Label(row,"(max "..MAX_PER_SLOT..")",9.5,C.TXT3,Enum.Font.Gotham)
    statusLbl.Size=UDim2.new(0,90,0,12); statusLbl.Position=UDim2.new(0,12,0,22)

    local ddBtn=Btn(row,C.DD_BG,UDim2.new(0.52,0,0,28))
    ddBtn.Position=UDim2.new(0.46,0,0.5,-14); Corner(ddBtn,6); Stroke(ddBtn,C.BORD2,1,0.3)

    local ddLbl=Label(ddBtn,"--",10.5,C.TXT2,Enum.Font.Gotham,Enum.TextXAlignment.Left)
    ddLbl.Size=UDim2.new(1,-20,1,0); ddLbl.Position=UDim2.new(0,7,0,0)
    ddLbl.TextTruncate=Enum.TextTruncate.AtEnd
    _slotSummaryLbls[slotIndex]=ddLbl

    local arrowLbl=Label(ddBtn,"▼",10,C.ACC,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
    arrowLbl.Size=UDim2.new(0,16,1,0); arrowLbl.Position=UDim2.new(1,-18,0,0)

    -- State popup aktif
    local _activeScrollPop = nil
    local _activeRowRefs   = {}
    local _activeCountLbl  = nil

    -- Rebuild isi popup (dipanggil saat popup terbuka & saat data baru masuk)
    local function RebuildPopupList()
        if not _activeScrollPop then return end
        for _, c in ipairs(_activeScrollPop:GetChildren()) do
            if c.ClassName~="UIListLayout" and c.ClassName~="UIPadding" then c:Destroy() end
        end
        _activeRowRefs = {}

        local list = QUIRK_LIST_PER_SLOT[slotIndex]

        if #list == 0 then
            _activeScrollPop.Size = UDim2.new(1,0,0,50)
            local el=Label(_activeScrollPop,"  ⏳ Tekan ReRoll manual 1x\n  di game untuk memuat data",
                10.5, Color3.fromRGB(255,180,80), Enum.Font.Gotham)
            el.Size=UDim2.new(1,-8,0,44); el.TextWrapped=true; el.LineHeight=1.4
            return
        end

        _activeScrollPop.Size = UDim2.new(1,0,0,min(#list*30+8,190))

        for _,q in ipairs(list) do
            local qRow=Btn(_activeScrollPop,C.DD_BG,UDim2.new(1,-8,0,28))
            qRow.ZIndex=9999; Corner(qRow,5)

            local tickBox=Frame(qRow,C.SEL_BG,UDim2.new(0,16,0,16))
            tickBox.Position=UDim2.new(0,6,0.5,-8); Corner(tickBox,3)
            tickBox.ZIndex=9999; Stroke(tickBox,C.BORD2,1,0.4)

            local tickMark=Label(tickBox,"✓",11,C.BLACK,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
            tickMark.Size=UDim2.new(1,0,1,0); tickMark.ZIndex=9999
            tickMark.Visible=(_slotTarget[slotIndex][q.id]==true)

            -- Nama: kalau masih "ID:xxxxx" tampilkan dengan warna beda + icon tanya
            local isResolved = not q.name:find("^ID:")
            local displayName = isResolved and q.name or ("❓ "..q.name)
            local nameColor   = isResolved and C.TXT or Color3.fromRGB(200,150,80)

            local qLbl=Label(qRow,"  "..displayName,11,nameColor,Enum.Font.Gotham)
            qLbl.Size=UDim2.new(1,-30,1,0); qLbl.Position=UDim2.new(0,28,0,0)
            qLbl.ZIndex=9999
            if _slotTarget[slotIndex][q.id] then qLbl.TextColor3=C.ACC2 end

            _activeRowRefs[q.id]={bg=qRow,tick=tickMark,lbl=qLbl}
            if _slotTarget[slotIndex][q.id] then qRow.BackgroundColor3=Color3.fromRGB(140,52,0) end

            qRow.MouseEnter:Connect(function()
                if not (_slotTarget[slotIndex][q.id]==true) then qRow.BackgroundColor3=C.DD_HOVER end end)
            qRow.MouseLeave:Connect(function()
                if not (_slotTarget[slotIndex][q.id]==true) then qRow.BackgroundColor3=C.DD_BG
                else qRow.BackgroundColor3=Color3.fromRGB(140,52,0) end end)

            qRow.MouseButton1Click:Connect(function()
                if _slotTarget[slotIndex][q.id]==true then
                    _slotTarget[slotIndex][q.id]=nil
                else
                    local n=0; for _ in pairs(_slotTarget[slotIndex]) do n=n+1 end
                    if n>=MAX_PER_SLOT then
                        if _activeCountLbl then
                            _activeCountLbl.TextColor3=Color3.fromRGB(255,60,60)
                            _activeCountLbl.Text="MAX "..MAX_PER_SLOT.." tercapai!"
                            task.delay(1.2,function()
                                if _activeCountLbl then
                                    local n2=0
                                    for _ in pairs(_slotTarget[slotIndex]) do n2=n2+1 end
                                    _activeCountLbl.Text=n2.."/"..MAX_PER_SLOT.." dipilih"
                                    _activeCountLbl.TextColor3=n2>=MAX_PER_SLOT
                                        and Color3.fromRGB(255,100,80) or C.ACC2
                                end
                            end)
                        end
                        return
                    end
                    _slotTarget[slotIndex][q.id]=true
                end
                -- Refresh visual semua row
                for qid,ref in pairs(_activeRowRefs) do
                    local sel=(_slotTarget[slotIndex][qid]==true)
                    ref.bg.BackgroundColor3=sel and Color3.fromRGB(140,52,0) or C.DD_BG
                    ref.tick.Visible=sel
                    ref.lbl.TextColor3=sel and C.ACC2 or (QUIRK_MAP[qid] and not tostring(QUIRK_MAP[qid]):find("^ID:") and C.TXT or Color3.fromRGB(200,150,80))
                end
                if _activeCountLbl then
                    local n=0; for _ in pairs(_slotTarget[slotIndex]) do n=n+1 end
                    _activeCountLbl.Text=n.."/"..MAX_PER_SLOT.." dipilih"
                    _activeCountLbl.TextColor3=n>=MAX_PER_SLOT and Color3.fromRGB(255,100,80) or C.ACC2
                end
                RefreshSlotUI(slotIndex)
            end)
        end
    end

    ddBtn.MouseButton1Click:Connect(function()
        CloseActiveDD()
        local absPos=ddBtn.AbsolutePosition
        local absSize=ddBtn.AbsoluteSize

        local popup=Frame(DDLayer,C.DD_BG,UDim2.new(0,absSize.X+30,0,0))
        popup.Position=UDim2.new(0,absPos.X,0,absPos.Y+absSize.Y+3)
        popup.AutomaticSize=Enum.AutomaticSize.Y
        popup.ZIndex=9999; Corner(popup,8); Stroke(popup,C.BORD2,1,0.2)
        popup.ClipsDescendants=true

        local popHeader=Frame(popup,Color3.fromRGB(90,30,0),UDim2.new(1,0,0,28))
        popHeader.ZIndex=9999

        local countLbl=Label(popHeader,"0/"..MAX_PER_SLOT.." dipilih",10.5,C.ACC2,Enum.Font.GothamBold)
        countLbl.Size=UDim2.new(0.6,0,1,0); countLbl.Position=UDim2.new(0,8,0,0)
        countLbl.ZIndex=9999
        _activeCountLbl=countLbl

        local clearBtn=Btn(popHeader,Color3.fromRGB(180,50,50),UDim2.new(0,50,0,20))
        clearBtn.Position=UDim2.new(1,-56,0.5,-10); Corner(clearBtn,5); clearBtn.ZIndex=9999
        local cLbl=Label(clearBtn,"Clear",10,Color3.fromRGB(255,255,255),Enum.Font.GothamBold,Enum.TextXAlignment.Center)
        cLbl.Size=UDim2.new(1,0,1,0); cLbl.ZIndex=9999

        local scrollPop=New("ScrollingFrame",{
            Parent=popup, Size=UDim2.new(1,0,0,50),
            Position=UDim2.new(0,0,0,28),
            BackgroundTransparency=1, BorderSizePixel=0,
            ScrollBarThickness=3, ScrollBarImageColor3=C.ACC,
            CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
            ZIndex=9999,
        })
        ListLayout(scrollPop,nil,Enum.HorizontalAlignment.Left,1)
        Padding(scrollPop,3,3,4,4)
        _activeScrollPop=scrollPop

        -- Update count
        local n=0; for _ in pairs(_slotTarget[slotIndex]) do n=n+1 end
        countLbl.Text=n.."/"..MAX_PER_SLOT.." dipilih"
        countLbl.TextColor3=n>=MAX_PER_SLOT and Color3.fromRGB(255,100,80) or C.ACC2

        RebuildPopupList()

        clearBtn.MouseButton1Click:Connect(function()
            _slotTarget[slotIndex]={}
            for _,ref in pairs(_activeRowRefs) do
                ref.bg.BackgroundColor3=C.DD_BG
                ref.tick.Visible=false
                ref.lbl.TextColor3=C.TXT
            end
            countLbl.Text="0/"..MAX_PER_SLOT.." dipilih"
            countLbl.TextColor3=C.ACC2
            RefreshSlotUI(slotIndex)
        end)

        DDLayer.Visible=true

        local function Close()
            popup:Destroy()
            _activeScrollPop=nil; _activeRowRefs={}; _activeCountLbl=nil
            DDLayer.Visible=false; _activeDDClose=nil
            RefreshSlotUI(slotIndex)
        end
        _activeDDClose=Close
    end)

    return row
end



