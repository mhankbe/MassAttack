StartWeaponSlotLoop = function(slotIndex)
    local slotPool = W_QUIRK_LIST_PER_SLOT[slotIndex]
    local allIds = {}
    for _,q in ipairs(slotPool) do table.insert(allIds, q.id) end
    local targets = {}
    for id,_ in pairs(_wSlotTarget[slotIndex]) do table.insert(targets, id) end
    local hasTarget = (#targets > 0)
    local targetStr = hasTarget and GetWeaponSlotSummary(slotIndex) or "apapun"

    _wSlotRunning[slotIndex] = true
    if _wWeaponSlotLbls[slotIndex] then
        _wWeaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": Mencari: "..targetStr
        _wWeaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(255,200,100)
    end

    LOOPS["wroll"..slotIndex] = task.spawn(function()
        local attempt = 0
        while _wSlotRunning[slotIndex] do
            attempt = attempt + 1
            local curTargets = {}
            for id,_ in pairs(_wSlotTarget[slotIndex]) do table.insert(curTargets, id) end
            local curHasTarget = (#curTargets > 0)
            local curStopIds = curHasTarget and curTargets or allIds
            local curTargetStr = curHasTarget and GetWeaponSlotSummary(slotIndex) or "apapun"

            if _wWeaponSlotLbls[slotIndex] then
                _wWeaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": #"..attempt.." → "..curTargetStr
                _wWeaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(255,200,100)
            end

            if not RE_RandomWeaponQuirk then task.wait(1); continue end

            local ok, result = pcall(function()
                return RE_RandomWeaponQuirk:InvokeServer({
                    guid   = _wGuid,
                    drawId = _wSlotDrawId[slotIndex],
                })
            end)

            if not ok then
                task.wait(0.5)
            elseif type(result) == "table" then
                local slotIdSet = {}
                for _,q in ipairs(slotPool) do slotIdSet[q.id] = true end
                local gotId = nil
                local PRIO = {"finalResultId","quirkId","resultId","id","Id","result","Result"}
                for _,key in ipairs(PRIO) do
                    local v = result[key]
                    if type(v)=="number" and (slotIdSet[v] or W_QUIRK_MAP[v]) then gotId=v; break end
                end
                if not gotId then
                    for _,v in pairs(result) do
                        if type(v)=="number" and (slotIdSet[v] or W_QUIRK_MAP[v]) then gotId=v; break end
                    end
                end

                local name = W_QUIRK_MAP[gotId] or (gotId and ("ID:"..tostring(gotId)) or "???")
                if _wWeaponSlotLbls[slotIndex] then
                    _wWeaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": "..name
                    _wWeaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(220,220,80)
                end

                local curTargetSet = {}
                for _,id in ipairs(curStopIds) do curTargetSet[id] = true end
                local isValid = gotId ~= nil and (slotIdSet[gotId] or W_QUIRK_MAP[gotId])
                local hit = isValid and (not curHasTarget or curTargetSet[gotId] == true)

                if hit then
                    StopWeaponSlotRoll(slotIndex)
                    if _wWeaponSlotLbls[slotIndex] then
                        _wWeaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": ✅ "..name
                        _wWeaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(80,220,80)
                    end
                    return
                end
                task.wait(0.05)
            else
                task.wait(0.3)
            end
        end
    end)
end

