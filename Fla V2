local _rollRunning = false

local function StopSlotRoll(slotIndex, reason)
    _slotRunning[slotIndex] = false
    StopLoop("roll"..slotIndex)
    if _slotStatusLbl[slotIndex] then
        _slotStatusLbl[slotIndex].Text = reason or "✓ Selesai"
        _slotStatusLbl[slotIndex].TextColor3 = Color3.fromRGB(80,220,80)
    end
    -- Hero Status label diupdate oleh StartSlotLoop saat hit, tidak perlu overwrite di sini
    if not (_slotRunning[1] or _slotRunning[2] or _slotRunning[3]) then
        _rollRunning = false
        STATE.autoRoll = false
        if _rerollStatusLbl then
            _rerollStatusLbl.Text = "✓ Semua slot selesai"
            _rerollStatusLbl.TextColor3 = Color3.fromRGB(80,220,80)
        end
        if _rollDotRef then _rollDotRef.BackgroundColor3=Color3.fromRGB(100,100,100) end
        RefreshStatus()
    end
end

local function StopAllRolls(reason)
    for i=1,3 do _slotRunning[i]=false end
    _rollRunning = false
    StopLoop("roll1"); StopLoop("roll2"); StopLoop("roll3")
    STATE.autoRoll = false
    if _rerollStatusLbl then
        _rerollStatusLbl.Text = reason or "Idle"
        _rerollStatusLbl.TextColor3 = Color3.fromRGB(80,220,80)
    end
    if _rollDotRef then _rollDotRef.BackgroundColor3=Color3.fromRGB(100,100,100) end
    RefreshStatus()
end

local function StartSlotLoop(slotIndex)
    -- Kumpulkan semua ID di pool slot ini sebagai stopQuirkIds default
    -- (berarti berhenti saat dapat quirk apapun dari slot ini)
    local slotPool = QUIRK_LIST_PER_SLOT[slotIndex]
    local allIdsInSlot = {}
    for _,q in ipairs(slotPool) do table.insert(allIdsInSlot, q.id) end

    -- Jika user pilih target tertentu, stopQuirkIds = target pilihan saja
    -- Jika tidak ada target, stopQuirkIds = semua ID slot (berhenti di quirk apapun)
    local targets = {}
    for id,_ in pairs(_slotTarget[slotIndex]) do table.insert(targets, id) end
    local hasTarget = (#targets > 0)
    local stopIds   = hasTarget and targets or allIdsInSlot
    local targetStr = hasTarget and GetSlotSummary(slotIndex) or "apapun"

    _slotRunning[slotIndex] = true

    if _slotStatusLbl[slotIndex] then
        _slotStatusLbl[slotIndex].Text = "⟳ rolling..."
        _slotStatusLbl[slotIndex].TextColor3 = Color3.fromRGB(255,200,100)
    end
    if _weaponSlotLbls[slotIndex] then
        _weaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": 🔄 Mencari: "..targetStr
        _weaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(255,200,100)
    end

    print("[Roll S"..slotIndex.."] START via AutoRandomHeroQuirk | drawId=".._slotDrawId[slotIndex]
        ..((_slotDrawIdCaptured[slotIndex] and " ✓captured") or " ⚠default")
        .." | stopQuirkIds="..#stopIds.." ids | target: "..targetStr)

    LOOPS["roll"..slotIndex] = task.spawn(function()
        local attempt = 0
        while _slotRunning[slotIndex] do
            attempt = attempt + 1

            -- Baca target terbaru (support ganti pilihan on-the-fly)
            local curTargets = {}
            for id,_ in pairs(_slotTarget[slotIndex]) do table.insert(curTargets, id) end
            local curHasTarget = (#curTargets > 0)
            local curStopIds   = curHasTarget and curTargets or allIdsInSlot
            local curTargetStr = curHasTarget and GetSlotSummary(slotIndex) or "apapun"

            if _slotStatusLbl[slotIndex] then
                _slotStatusLbl[slotIndex].Text = "⟳ #"..attempt.." | "..curTargetStr
                _slotStatusLbl[slotIndex].TextColor3 = Color3.fromRGB(255,200,100)
            end
            if _weaponSlotLbls[slotIndex] then
                _weaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": 🔄 #"..attempt.." → "..curTargetStr
                _weaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(255,200,100)
            end

            local ok, result = pcall(function()
                return RE_AutoHeroQuirk:InvokeServer({
                    heroGuid    = _rollHeroGuid,
                    drawId      = _slotDrawId[slotIndex],
                    stopQuirkIds = curStopIds,
                })
            end)

            if not ok then
                warn("[Roll S"..slotIndex.."] AutoQuirk error #"..attempt.." — fallback RandomHeroQuirk")
                if _weaponSlotLbls[slotIndex] then
                    _weaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": ⚠ Error, retry..."
                    _weaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(255,80,80)
                end
                -- Fallback ke RandomHeroQuirk manual jika AutoRandomHeroQuirk gagal
                pcall(function()
                    RE_RandomHeroQuirk:InvokeServer({
                        heroGuid = _rollHeroGuid,
                        drawId   = _slotDrawId[slotIndex],
                    })
                end)
                task.wait(1)
            elseif type(result) == "table" then
                -- Deep scan result untuk cari gotId
                local slotIdSet = {}
                for _,q in ipairs(slotPool) do slotIdSet[q.id]=true end

                local function ScanResultForId(tbl, depth)
                    if depth > 3 then return nil end
                    local PRIO_KEYS = {
                        "finalResultId","quirkId","resultId","quirk_id",
                        "id","Id","ID","result","Result","finalId","drawResultId"
                    }
                    for _,key in ipairs(PRIO_KEYS) do
                        local v = tbl[key]
                        if type(v)=="number" and slotIdSet[v] then return v end
                        if type(v)=="number" and QUIRK_MAP[v]  then return v end
                    end
                    for _,v in pairs(tbl) do
                        if type(v)=="number" and slotIdSet[v] then return v end
                        if type(v)=="table"  then
                            local f = ScanResultForId(v, depth+1)
                            if f then return f end
                        end
                    end
                    for _,v in pairs(tbl) do
                        if type(v)=="number" and QUIRK_MAP[v] then return v end
                    end
                    return nil
                end

                local gotId = ScanResultForId(result, 0)

                -- Debug dump 3 kali pertama untuk semua slot
                if attempt <= 3 then
                    local dump = "[ ASH DEBUG S"..slotIndex.." #"..attempt.." ] "
                    for k,v in pairs(result) do
                        dump = dump..tostring(k).."="..tostring(v).." | "
                    end
                    print(dump)
                    print("[ ASH DEBUG S"..slotIndex.."] gotId → "
                        ..tostring(gotId).." = "..(QUIRK_MAP[gotId] or "?"))
                end

                local name = QUIRK_MAP[gotId] or (gotId and ("ID:"..tostring(gotId)) or "???")
                print("[Roll S"..slotIndex.."] #"..attempt.." → "..name)

                if _weaponSlotLbls[slotIndex] then
                    _weaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": ⚡ "..name
                    _weaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(220,220,80)
                end

                -- Cek apakah hasil ini adalah target yang dicari
                local curTargetSet = {}
                for _,id in ipairs(curStopIds) do curTargetSet[id]=true end
                local hit = (gotId~=nil) and (not curHasTarget or curTargetSet[gotId]==true)

                if hit then
                    StopSlotRoll(slotIndex, "✓ "..name.." (#"..attempt..")")
                    if _weaponSlotLbls[slotIndex] then
                        _weaponSlotLbls[slotIndex].Text = "Slot "..slotIndex..": ✅ "..name
                        _weaponSlotLbls[slotIndex].TextColor3 = Color3.fromRGB(80,220,80)
                    end
                    return
                end
                task.wait(0.05)
            else
                warn("[Roll S"..slotIndex.."] result bukan table: "..tostring(result))
                task.wait(0.5)
            end
        end
        print("[Roll S"..slotIndex.."] loop berhenti.")
    end)
end

local function DoAutoRoll(on)
    for i=1,3 do _slotRunning[i]=false end
    task.wait(0.1)
    StopLoop("roll1"); StopLoop("roll2"); StopLoop("roll3")
    if not on then
        if _rerollStatusLbl then _rerollStatusLbl.Text="Idle"; _rerollStatusLbl.TextColor3=C.TXT2 end
        if _rollDotRef then _rollDotRef.BackgroundColor3=Color3.fromRGB(100,100,100) end
        for i=1,3 do
            if _slotStatusLbl[i] then _slotStatusLbl[i].Text="Idle"; _slotStatusLbl[i].TextColor3=C.TXT2 end
        end
        return
    end
    if not _rollCaptured or _rollHeroGuid=="" then
        if _rerollStatusLbl then
            _rerollStatusLbl.Text="⚠ Klik ReRoll manual 1x dulu!"
            _rerollStatusLbl.TextColor3=Color3.fromRGB(255,100,60)
        end
        STATE.autoRoll=false; RefreshStatus(); return
    end
    _rollRunning = true
    if _rollDotRef then _rollDotRef.BackgroundColor3=Color3.fromRGB(255,200,60) end
    print("[Roll] START 3 slot paralel — heroGuid=".._rollHeroGuid)
    StartSlotLoop(1)
    StartSlotLoop(2)
    StartSlotLoop(3)
end

