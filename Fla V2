    local eBtnRefresh=Btn(eHeaderRow,Color3.fromRGB(20,80,40),UDim2.new(0,80,0,20))
    eBtnRefresh.Position=UDim2.new(1,-80,0,1); Corner(eBtnRefresh,6)
    Stroke(eBtnRefresh,C.GRN,1,0.3)
    local eBtnRefLbl=Label(eBtnRefresh,"Refresh",9,C.GRN,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
