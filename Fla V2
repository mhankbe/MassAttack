-- LOGIC : AUTO ROLL
-- =====================================================
local _rollHeroGuid   = ""
local _rollTargetIds  = {}   -- {[id]=true} quirk yang jadi stop condition
local _rollCaptured   = false
local _rollStatusLbl  = nil  -- label status di panel (diisi nanti)

-- Hook AutoRandomHeroQuirk untuk capture heroGuid otomatis
-- Saat user klik StartReroll di game 1x → kita tangkap heroGuid-nya
local _hookConn = nil
local function SetupHeroGuidHook(onCapture)
    pcall(function()
        local remote = RE_AutoHeroQuirk
        local oldInvoke
        oldInvoke = hookfunction(remote.InvokeServer, function(self, args)
            if args and args.heroGuid and not _rollCaptured then
                _rollHeroGuid  = args.heroGuid
                _rollCaptured  = true
                if _rollStatusLbl then
                    _rollStatusLbl.Text = "✓ heroGuid tertangkap!"
                    _rollStatusLbl.TextColor3 = Color3.fromRGB(80,220,80)
                end
                if onCapture then onCapture(args.heroGuid) end
                print("[ ASH Roll ] heroGuid captured: "..args.heroGuid)
            end
            return oldInvoke(self, args)
        end)
    end)
end

local function DoAutoRoll(on)
    StopLoop("roll")
    if not on then return end

    if not _rollHeroGuid or _rollHeroGuid == "" then
        print("[ ASH ] heroGuid belum tertangkap! Klik StartReroll di game dulu 1x.")
        if _rollStatusLbl then
            _rollStatusLbl.Text = "⚠ Klik StartReroll di game dulu 1x!"
            _rollStatusLbl.TextColor3 = Color3.fromRGB(255,180,60)
        end
        STATE.autoRoll = false
        RefreshStatus()
        return
    end

    -- Kumpulkan semua stopQuirkIds dari pilihan user
    local stopIds = {}
    for id, selected in pairs(_rollTargetIds) do
        if selected then
            table.insert(stopIds, id)
        end
    end

    -- Kalau tidak ada yang dicentang → pakai semua ID (stop di quirk apapun)
    if #stopIds == 0 then
        for _, q in ipairs(QUIRK_LIST) do
            table.insert(stopIds, q.id)
        end
    end

    if _rollStatusLbl then
        _rollStatusLbl.Text = "⟳ Rolling... ("..#stopIds.." target)"
        _rollStatusLbl.TextColor3 = Color3.fromRGB(255,200,100)
    end

    LOOPS["roll"] = task.spawn(function()
        while STATE.autoRoll do
            local result = nil
            pcall(function()
                result = RE_AutoHeroQuirk:InvokeServer({
                    heroGuid     = _rollHeroGuid,
                    drawId       = 920001,
                    stopQuirkIds = stopIds,
                })
            end)

            -- Cek apakah server return quirk yang match
            if result then
                local gotId = nil
                if type(result) == "table" then
                    gotId = result.quirkId or result.id or result[1]
                elseif type(result) == "number" then
                    gotId = result
                end

                if gotId and _rollTargetIds[gotId] then
                    -- Target quirk didapat! Stop
                    STATE.autoRoll = false
                    StopLoop("roll")
                    local name = ""
                    for _, q in ipairs(QUIRK_LIST) do
                        if q.id == gotId then name = q.name; break end
                    end
                    if _rollStatusLbl then
                        _rollStatusLbl.Text = "✓ Dapat: "..name.."!"
                        _rollStatusLbl.TextColor3 = Color3.fromRGB(80,220,80)
                    end
                    print("[ ASH Roll ] Target didapat: "..name)
                    RefreshStatus()
                    break
                end
            end

            task.wait(0.5)
        end
    end)
end

