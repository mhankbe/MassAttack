-- LAYER 2 : DEEP SCAN seluruh game tree
-- Scan UUID dari semua Instance + attribute di game
-- =====================================================
local function ScanHeroGuidFromData()
    if _rollCaptured then return true end

    -- Key-key yang sering dipakai untuk menyimpan heroGuid
    local GUID_KEYS = {
        "heroGuid","HeroGuid","hero_guid","HEROGUID",
        "guid","GUID","Guid",
        "heroId","HeroId","hero_id",
        "entityGuid","EntityGuid",
        "selectedHero","SelectedHero",
        "activeHero","ActiveHero",
    }

    local function TryScanInstance(obj)
        if not obj then return end
        -- Cek semua attribute
        pcall(function()
            local attrs = obj:GetAttributes()
            for k,v in pairs(attrs) do
                if type(v)=="string" and IsValidUUID(v) then
                    local kl=k:lower()
                    if kl:find("guid") or kl:find("hero") or kl:find("id") then
                        SetHeroGuid(v,"scan:attr:"..obj.Name.."."..k)
                        if _rollCaptured then return end
                    end
                end
            end
        end)
        -- Cek StringValue / children
        pcall(function()
            for _,key in ipairs(GUID_KEYS) do
                local child=obj:FindFirstChild(key)
                if child and child.Value and IsValidUUID(tostring(child.Value)) then
                    SetHeroGuid(tostring(child.Value),"scan:child:"..obj.Name.."."..key)
                    if _rollCaptured then return end
                end
            end
        end)
    end

    -- Scan dari berbagai root
    local roots = {
        LP, LP.Character,
        LP:FindFirstChild("leaderstats"),
        LP:FindFirstChild("PlayerData"),
        LP:FindFirstChild("Data"),
        RS:FindFirstChild("PlayerData"),
        RS:FindFirstChild("Data"),
        RS:FindFirstChild("Players"),
        workspace:FindFirstChild("Players"),
        workspace:FindFirstChild("Characters"),
    }

    for _,root in ipairs(roots) do
        if _rollCaptured then return true end
        if root then
            TryScanInstance(root)
            -- Scan satu level dalam
            pcall(function()
                for _,child in ipairs(root:GetChildren()) do
                    if _rollCaptured then break end
                    TryScanInstance(child)
                end
            end)
        end
    end

    -- Coba scan khusus folder player di RS
    pcall(function()
        for _,folder in ipairs(RS:GetChildren()) do
            if _rollCaptured then break end
            local myFolder = folder:FindFirstChild(LP.Name)
                or folder:FindFirstChild(tostring(LP.UserId))
            if myFolder then
                TryScanInstance(myFolder)
                for _,c in ipairs(myFolder:GetChildren()) do
                    if _rollCaptured then break end
                    TryScanInstance(c)
                end
            end
        end
    end)

    return _rollCaptured
end

-- =====================================================
-- LAYER 3 : ATTRIBUTE CHANGE WATCHER
-- Pasang :GetAttributeChangedSignal pada semua
-- instance yang mungkin punya heroGuid, auto capture
-- saat nilainya berubah/di-set
-- =====================================================
local _watcherConns = {}
local function SetupAttributeWatcher()
    if #_watcherConns > 0 then return end

    local WATCH_KEYS = {"heroGuid","HeroGuid","guid","GUID","heroId","HeroId","selectedHero"}

    local function WatchInstance(obj)
        if not obj then return end
        for _,key in ipairs(WATCH_KEYS) do
            pcall(function()
                local conn = obj:GetAttributeChangedSignal(key):Connect(function()
                    if _rollCaptured then return end
                    local v = obj:GetAttribute(key)
                    if v and IsValidUUID(tostring(v)) then
                        SetHeroGuid(tostring(v), "watcher:"..obj.Name.."."..key)
                    end
                end)
                table.insert(_watcherConns, conn)
            end)
        end
    end

    -- Watch instance-instance kunci
    WatchInstance(LP)
    if LP.Character then WatchInstance(LP.Character) end
    LP.CharacterAdded:Connect(function(char) WatchInstance(char) end)

    -- Watch RS.DescendantAdded — kalau ada folder/object baru dengan UUID
    table.insert(_watcherConns, RS.DescendantAdded:Connect(function(obj)
        if _rollCaptured then return end
        pcall(function()
            local attrs = obj:GetAttributes()
            for k,v in pairs(attrs) do
                if type(v)=="string" and IsValidUUID(v) then
                    SetHeroGuid(v,"watcher:RS.new:"..obj.Name.."."..k)
                    if _rollCaptured then return end
                end
            end
        end)
        WatchInstance(obj)
    end))

    print("[ ASH ] Layer 3 (Attribute Watcher) aktif ✓")
end

