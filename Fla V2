        cLbl.Size=UDim2.new(1,0,1,0); cLbl.ZIndex=9999

        local scrollPop=New("ScrollingFrame",{
            Parent=popup, Size=UDim2.new(1,0,0,50),
            Position=UDim2.new(0,0,0,28),
            BackgroundTransparency=1, BorderSizePixel=0,
            ScrollBarThickness=_isSmallScreen and 5 or 3, ScrollBarImageColor3=C.ACC,
            CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
            ZIndex=9999,
