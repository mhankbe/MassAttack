local function InitAllCaptureLayers()
    print("[ ASH ] Initializing capture layers...")

    -- Layer 0: Universal Remote Spy — PERTAMA & PALING KUAT
    SetupUniversalSpy()

    task.spawn(function()
        task.wait(0.3)

        -- Layer 2: Deep scan data lokal
        if not _rollCaptured then
            ScanHeroGuidFromData()
        end

        task.wait(0.2)

        -- Layer 3: Attribute watcher
        if not _rollCaptured then
            SetupAttributeWatcher()
        end

        -- Update status UI
        if not _rollCaptured then
            if _captureStatusLbl then
                _captureStatusLbl.Text = "⟳ Spy aktif — klik ReRoll 1x di game"
                _captureStatusLbl.TextColor3 = Color3.fromRGB(255,200,100)
            end
        end
    end)

    -- Periodik re-scan setiap 4 detik sampai berhasil
    task.spawn(function()
        local attempt = 0
        while not _rollCaptured do
            task.wait(4)
            attempt = attempt + 1
            if not _rollCaptured then
                print("[ ASH ] Re-scan #"..attempt.."...")
                ScanHeroGuidFromData()
                -- Setelah 5 kali gagal, log semua UUID yang pernah ketangkap spy
                if attempt >= 5 and not _rollCaptured then
                    local count = 0
                    for uuid,src in pairs(_spyLog) do
                        count = count + 1
                        print("[ ASH SPY LOG #"..count.."] "..uuid.." | "..src)
                    end
                    if count == 0 then
                        print("[ ASH ] Belum ada UUID yang tertangkap spy sama sekali.")
                        if _captureStatusLbl then
                            _captureStatusLbl.Text = "⚠ Belum ada UUID — pastikan panel ReRoll terbuka di game"
                            _captureStatusLbl.TextColor3 = Color3.fromRGB(255,80,80)
                        end
                    else
                        print("[ ASH ] "..count.." UUID tertangkap spy tapi belum match — cek console")
                        if _captureStatusLbl then
                            _captureStatusLbl.Text = "⚠ "..count.." UUID spy — belum ada yg cocok, cek console"
                            _captureStatusLbl.TextColor3 = Color3.fromRGB(255,150,50)
                        end
                    end
                end
            end
        end
        print("[ ASH ] Capture berhasil! Loop scan berhenti.")
    end)
end

