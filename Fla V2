local bubbleConn
local function StopFloat()
    if bubbleConn then bubbleConn:Disconnect(); bubbleConn=nil end
end
local function StartFloat()
    StopFloat()
    local t     = 0
    local baseX = Bubble.Position.X.Offset
    local baseY = Bubble.Position.Y.Offset
    bubbleConn  = RunService.Heartbeat:Connect(function(dt)
        t = t + dt
        Bubble.Position = UDim2.new(0, baseX, 0, baseY + math.sin(t*2)*8)
    end)
end

-- Drag dengan threshold supaya klik biasa tidak terhitung drag
local bDrag        = false
local bDragMoved   = false
local bDragStart   = nil
local bStartPos    = nil
local DRAG_THRESH  = 6

Bubble.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then
        bDrag=true; bDragMoved=false
        bDragStart=i.Position; bStartPos=Bubble.Position
        StopFloat()
    end
end)

Bubble.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then
        local wasDrag = bDragMoved
        bDrag=false; bDragMoved=false
        if wasDrag then
            -- Selesai drag → lanjut float di posisi baru
            if Bubble.Visible then StartFloat() end
        else
            -- Klik biasa → restore window
            StopFloat()
            Bubble.Visible = false
            Window.Visible = true
        end
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if bDrag and (i.UserInputType==Enum.UserInputType.MouseMovement
    or i.UserInputType==Enum.UserInputType.Touch) then
        local d = i.Position - bDragStart
        if math.abs(d.X)>DRAG_THRESH or math.abs(d.Y)>DRAG_THRESH then
            bDragMoved=true
        end
        if bDragMoved then
            Bubble.Position=UDim2.new(0,bStartPos.X.Offset+d.X,0,bStartPos.Y.Offset+d.Y)
        end
    end
end)

BtnMin.MouseButton1Click:Connect(function()
    Window.Visible=false
    Bubble.Position=UDim2.new(0,20,0.5,-30)
    Bubble.Visible=true
    StartFloat()
end)

