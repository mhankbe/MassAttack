local function ExtractUUIDs(val, depth, found)
    depth = depth or 0
    found = found or {}
    if depth > 5 then return found end
    local t = type(val)
    if t=="string" then
        if IsValidUUID(val) then found[val]=true end
    elseif t=="table" then
        for k,v in pairs(val) do
            if type(k)=="string" then
                local kl = k:lower()
                if (kl:find("guid") or kl:find("hero") or kl:find("id"))
                    and type(v)=="string" and IsValidUUID(v) then
                    found[v] = (kl:find("guid") or kl:find("hero")) and "priority" or true
                end
            end
            ExtractUUIDs(v, depth+1, found)
        end
    end
    return found
end

SetHeroGuid = function(guid, method)
    if not guid or guid=="" then return end
    if not IsValidUUID(guid) then return end
    if _rollHeroGuid == guid then return end

    local isSwitch = _rollCaptured and _rollHeroGuid ~= "" and _rollHeroGuid ~= guid
    _rollHeroGuid  = guid
    _rollCaptured  = true
    _captureMethod = method or "unknown"

    if _rerollStatusLbl then
        local txt = isSwitch
            and "Hero berganti — GUID updated!"
            or  "Captured ["..(_captureMethod).."] — siap reroll"
        _rerollStatusLbl.Text = txt
        _rerollStatusLbl.TextColor3 = Color3.fromRGB(80,220,80)
    end
    if _captureStatusLbl then
        _captureStatusLbl.Text = "["..(_captureMethod).."] — ".._rollHeroGuid:sub(1,18).."..."
        _captureStatusLbl.TextColor3 = Color3.fromRGB(80,220,80)
    end
    if _rollDotRef then
        _rollDotRef.BackgroundColor3 = Color3.fromRGB(80,220,80)
    end

    if isSwitch and STATE.autoRoll then
        task.spawn(function()
            for i = 1, 3 do
                _slotRunning[i] = false
                StopLoop("roll"..i)
            end
            task.wait(0.1)
            if not STATE.autoRoll then return end
            for i = 1, 3 do
                StartSlotLoop(i)
            end
            if _rerollStatusLbl then
                _rerollStatusLbl.Text = "Restart — hero baru aktif"
                _rerollStatusLbl.TextColor3 = Color3.fromRGB(255,200,60)
            end
        end)
    end
end

