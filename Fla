local function GetEnemies()
    local list={}
    local f=workspace:FindFirstChild("Enemys"); if not f then return list end
    for _,e in ipairs(f:GetChildren()) do
        if e:IsA("Model") then
            local g=e:GetAttribute("EnemyGuid"); local h=e:FindFirstChild("HumanoidRootPart"); local hum=e:FindFirstChildOfClass("Humanoid")
            if g and h and hum and hum.Health>0 then table.insert(list,{model=e,guid=g,hrp=h}) end
        end
    end
