-- ── AUTO SKILL (Z X C V F) ───────────────────────────
-- Di PC  : simulasi keypress Z/X/C/V/F via VirtualInputManager
-- Di HP  : sama, VirtualInputManager juga bekerja di mobile executor
local VIM = game:GetService("VirtualInputManager")

local AutoSkill = {
    Z = { on=false, key=Enum.KeyCode.Z, thread=nil, delay=1.0 },
    X = { on=false, key=Enum.KeyCode.X, thread=nil, delay=1.0 },
    C = { on=false, key=Enum.KeyCode.C, thread=nil, delay=1.0 },
    V = { on=false, key=Enum.KeyCode.V, thread=nil, delay=1.0 },
    F = { on=false, key=Enum.KeyCode.F, thread=nil, delay=1.0 },
}
local SKILL_ORDER = {"Z","X","C","V","F"}

local function PressKey(keyCode)
    pcall(function()
        VIM:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        VIM:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function StartSkill(name)
    local sk = AutoSkill[name]
    if sk.thread then return end
    sk.on = true
    sk.thread = task.spawn(function()
        while sk.on do
            PressKey(sk.key)
            task.wait(sk.delay)
        end
        sk.thread = nil
    end)
end

local function StopSkill(name)
    local sk = AutoSkill[name]
    sk.on = false
    if sk.thread then
        pcall(function() task.cancel(sk.thread) end)
        sk.thread = nil
    end
end

local function StartMassAttack(onStatus, onToggle)
    if MassAttack.running then return end
    MassAttack.running   = true
    MassAttack.killed    = 0
    MassAttack.collected = 0

    StartDestroyerWorker()

    MassAttack.thread = task.spawn(function()
        -- Index map terakhir yang dikunjungi (untuk melanjutkan urutan)
        local lastMapIdx = 0

        while MassAttack.running do

            -- ── Baca pilihan map SEKARANG (real-time) ──────────
            local selectedMaps = {}
            for i = 1, #MAPS do
                if MapRotation.selected[i] then
                    table.insert(selectedMaps, i)
                end
            end

            if #selectedMaps > 0 then
                -- Cari map berikutnya setelah lastMapIdx dalam urutan selectedMaps
                local nextMapIdx = nil
                for _, mapIdx in ipairs(selectedMaps) do
                    if mapIdx > lastMapIdx then
                        nextMapIdx = mapIdx
                        break
                    end
                end
                -- Jika sudah habis / tidak ada yg lebih besar → kembali ke awal
                if not nextMapIdx then
                    nextMapIdx  = selectedMaps[1]
                    lastMapIdx  = 0
                end
                lastMapIdx = nextMapIdx

                local mapData = MAPS[nextMapIdx]

                if onStatus then onStatus("🗺 Teleport → "..mapData.name.."...", true) end
                TeleportToMap(mapData)

                local d = 0
                while d < MapRotation.teleportDelay and MassAttack.running do
                    task.wait(0.2); d = d + 0.2
                end
                if not MassAttack.running then break end

                local targetLabel = MassAttack.killTarget == 0 and "All" or tostring(MassAttack.killTarget)
                if onStatus then
                    onStatus("⚔ "..mapData.name.." — target "..targetLabel.." kill", true)
                end
                local done = AttackUntilKillTarget(onStatus)

                if not done or not MassAttack.running then break end

                local delay = MapRotation.nextMapDelay
                local doneLabel = MassAttack.killTarget == 0 and "All killed!" or (tostring(MassAttack.killTarget).." kill!")
                if onStatus then
                    onStatus("✅ "..doneLabel.."  Pindah dalam "..delay.."s...", true)
                end
                d = 0
                while d < MapRotation.nextMapDelay and MassAttack.running do
                    task.wait(0.2); d = d + 0.2
                end

            else
                -- Tidak ada map dipilih → farm di map saat ini saja
                lastMapIdx = 0
                local done = AttackUntilKillTarget(onStatus)
                if done and MassAttack.running then
                    local delay = MapRotation.nextMapDelay
                    local doneLabel = MassAttack.killTarget == 0 and "All killed!" or (tostring(MassAttack.killTarget).." kill!")
                    if onStatus then
                        onStatus("✅ "..doneLabel.."  Ulang dalam "..delay.."s...", true)
                    end
                    local d = 0
                    while d < MapRotation.nextMapDelay and MassAttack.running do
                        task.wait(0.2); d = d + 0.2
                    end
                end
            end
        end

        MassAttack.running = false
        if onToggle then onToggle(false) end
    end)
end

local function StopMassAttack()
    MassAttack.running = false
    if MassAttack.thread then
        task.cancel(MassAttack.thread)
        MassAttack.thread = nil
    end
end

local function StopMapRotation()
    StopMassAttack()
end

