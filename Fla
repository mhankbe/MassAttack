-- ── GET ENEMIES ──────────────────────────────────────
local function GetEnemies()
    local list   = {}
    local folder = workspace:FindFirstChild("Enemys")
    if not folder then return list end
    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") then
            local guid = enemy:GetAttribute("EnemyGuid")
            local hrp  = enemy:FindFirstChild("HumanoidRootPart")
            local hum  = enemy:FindFirstChildOfClass("Humanoid")
            if guid and hrp and hum and hum.Health > 0 then
                table.insert(list, {
                    model = enemy,
                    guid  = guid,
                    hrp   = hrp,
                })
            end
        end
    end
    return list
end

-- ── AUTO COLLECT via DropItems event ─────────────────
local collectedGuids = {}

local RE_DropItems = Remotes:WaitForChild("DropItems")
RE_DropItems.OnClientEvent:Connect(function(data)
    if not MassAttack.autoCollect then return end
    if not data or not data.rewards then return end
    task.spawn(function()
        for _, reward in pairs(data.rewards) do
            if type(reward) == "table" and reward.guid then
                local guid = reward.guid
                if not collectedGuids[guid] then
                    collectedGuids[guid] = true
                    pcall(function()
                        RE_Collect:InvokeServer(guid)
                    end)
                    MassAttack.collected = MassAttack.collected + 1
                    task.wait(0.02)
                end
            end
        end
    end)
end)

