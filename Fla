-- DRAG — PC & Mobile (menggunakan AbsolutePosition)
-- =====================================================
do
    local dragging   = false
    local dragStartMouse = Vector2.new(0, 0)
    local dragStartWin   = Vector2.new(0, 0)

    local function BeginDrag(inputPos)
        dragging = true
        dragStartMouse = Vector2.new(inputPos.X, inputPos.Y)
        dragStartWin   = Vector2.new(Win.AbsolutePosition.X, Win.AbsolutePosition.Y)
    end

    local function UpdateDrag(inputPos)
        if not dragging then return end
        local dx = inputPos.X - dragStartMouse.X
        local dy = inputPos.Y - dragStartMouse.Y
        local vp = game:GetService("GuiService"):GetGuiInset()
        local screenX = workspace.CurrentCamera.ViewportSize.X
        local screenY = workspace.CurrentCamera.ViewportSize.Y
        local newX = math.clamp(dragStartWin.X + dx, 0, screenX - Win.AbsoluteSize.X)
        local newY = math.clamp(dragStartWin.Y + dy - vp.Y, 0, screenY - Win.AbsoluteSize.Y)
        Win.Position = UDim2.new(0, newX, 0, newY)
    end

    -- TBar tangkap drag awal
    TBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            BeginDrag(i.Position)
        end
    end)

    -- Global InputChanged untuk update posisi
    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then
            UpdateDrag(i.Position)
        end
    end)

    -- Stop drag saat lepas
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

