-- =====================================================
-- NO CLIP
-- Fallback otomatis:
--   Method 1: sethiddenproperty (CanCollide hidden prop)
--   Method 2: Loop set CanCollide=false tiap Heartbeat
-- Berlaku untuk karakter utama + auto re-apply saat respawn.
-- =====================================================
local ncLoop = nil
local NC_METHOD = nil  -- akan di-detect saat pertama aktif

local function SetPartNoCollide(part, state)
    -- Coba method 1: sethiddenproperty
    if NC_METHOD == nil or NC_METHOD == 1 then
        local ok = pcall(function()
            sethiddenproperty(part, "CanCollide", not state)
        end)
        if ok and NC_METHOD == nil then NC_METHOD = 1 end
        if NC_METHOD == 1 then return end
    end
    -- Fallback method 2: langsung set property
    pcall(function() part.CanCollide = not state end)
    if NC_METHOD == nil then NC_METHOD = 2 end
end

local function ApplyNoClip(char, enable)
    if not char then return end
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            SetPartNoCollide(p, enable)
        end
    end
    -- HumanoidRootPart juga perlu no collide
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then SetPartNoCollide(hrp, enable) end
end

local function StartNoClip()
    PS.noClip = true
    -- Loop Heartbeat — re-apply ke SEMUA part tiap frame
    -- supaya server tidak bisa reset collision
    ncLoop = RunService.Heartbeat:Connect(function()
        if not PS.noClip then return end
        local char = LP.Character
        if not char then return end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                SetPartNoCollide(p, true)
            end
        end
    end)
end

local function StopNoClip()
    PS.noClip = false
    if ncLoop then pcall(function() ncLoop:Disconnect() end); ncLoop = nil end
    -- Kembalikan collision normal
    ApplyNoClip(LP.Character, false)
end

-- Re-apply saat respawn
LP.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if PS.noClip then
