local function FmtTime(s)
    local h=math.floor(s/3600); local m=math.floor((s%3600)/60); local sc=s%60
    if h>0 then return h.."j "..string.format("%02d",m).."m "..string.format("%02d",sc).."s"
    elseif m>0 then return m.."m "..string.format("%02d",sc).."s"
    else return sc.."s" end
end

