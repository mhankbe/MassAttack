-- Hook FireServer untuk intercept HeroMoveToEnemyPos
pcall(function()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if (method == "FireServer" or method == "InvokeServer") and self == RE_HeroMove then
            local args = {...}
            if args[1] and type(args[1]) == "table" and args[1].heroTagetPosInfos then
                -- Ambil semua hero guid dari heroTagetPosInfos
                local newGuids = {}
                for hGuid, _ in pairs(args[1].heroTagetPosInfos) do
                    table.insert(newGuids, hGuid)
                end
                if #newGuids > 0 then
                    HERO_GUIDS = newGuids
                    -- Print sekali saat pertama kali dapat guid
                    if #HERO_GUIDS > 0 then
                        print("✅ Hero guids captured: "..#HERO_GUIDS.." heroes")
                        for _, g in ipairs(HERO_GUIDS) do print("   →", g) end
                    end
                end
            end
        end
        return oldNamecall(self, ...)
    end)
end)

