-- Slider drag logic (snap per 10%)
local sliderDragging = false
local function SliderFromInput(inputX)
    local absPos  = sliderTrackBg.AbsolutePosition.X
    local absSize = sliderTrackBg.AbsoluteSize.X
    local ratio   = math.clamp((inputX - absPos) / absSize, 0, 1)
    local pct     = math.floor(ratio * SPEED_MAX / 10 + 0.5) * 10  -- snap per 10%
    UpdateSpeedSlider(pct)
end

sliderTrackBg.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1
    or i.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        SliderFromInput(i.Position.X)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if sliderDragging and (
        i.UserInputType == Enum.UserInputType.MouseMovement or
        i.UserInputType == Enum.UserInputType.Touch) then
        SliderFromInput(i.Position.X)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1
    or i.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = false
    end
end)

