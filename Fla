-- ── HELPER ───────────────────────────────────────────
local function IsEnemyDead(e)
    -- Cek deadGuids global (dari EnemyDeath event)
    if deadGuids[e.guid] then return true end
    -- Cek model masih ada di workspace
    if not e.model or not e.model.Parent then return true end
    -- Cek Humanoid Health secara langsung (sumber kebenaran utama)
    local hum = e.model:FindFirstChildOfClass("Humanoid")
    return not hum or hum.Health <= 0
end

