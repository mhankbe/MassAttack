local AR_statusCb = nil  -- callback untuk update UI

local function AR_GetMapIdsForMode()
    -- Return list mapId yang akan dicoba sesuai pickMode
    if AR.pickMode == "Preferred" then
        if #AR.prefMaps > 0 then return AR.prefMaps end
        -- fallback: semua map
        local all={}; for i=1,18 do all[i]=i end; return all
    end
    for _, rk in ipairs(RAID_RANKS) do
        if rk.name == AR.pickMode then
            local list={}
            for i=rk.minLv, rk.maxLv do list[#list+1]=i end
            return list
        end
    end
    local all={}; for i=1,18 do all[i]=i end; return all
end

local function AR_GetRankName(mapId)
    for _, rk in ipairs(RAID_RANKS) do
        if mapId >= rk.minLv and mapId <= rk.maxLv then return rk.name end
    end
    return "?"
end

local function AR_GetPortalPos(mapId)
    local Map = workspace:FindFirstChild("Map")
    local RE = Map and Map:FindFirstChild("RaidEnter")
    if not RE then return nil end
    for _, folder in ipairs(RE:GetChildren()) do
        for _, model in ipairs(folder:GetChildren()) do
            if model.Name == "RaidEnter"..mapId then
                local rp = model:FindFirstChild("RootPart")
                if rp then return rp.Position end
                for _, p in ipairs(model:GetDescendants()) do
                    if p:IsA("BasePart") then return p.Position end
                end
            end
        end
    end
    return nil
end

local function AR_GetBossParts()
    local Map = workspace:FindFirstChild("Map")
    local MB = Map and Map:FindFirstChild("MapBoss")
    if not MB then return {} end
    local list={}
    for _, p in ipairs(MB:GetChildren()) do
        if p:IsA("BasePart") then list[#list+1]=p end
    end
    return list
end

local function AR_GetRaidEnemies()
    local Map = workspace:FindFirstChild("Map")
    local RE = Map and Map:FindFirstChild("RaidsEnemys")
    if not RE then return {} end
    local list={}
    for _, p in ipairs(RE:GetChildren()) do
        if p:IsA("BasePart") then
            local sid=p:GetAttribute("SpawnId"); local eid=p:GetAttribute("EnemyId")
            if sid then list[#list+1]={part=p,spawnId=sid,enemyId=eid} end
        end
    end
    return list
end

local function AR_FireDmg(spawnId, enemyId, pos)
    pcall(function() RE_Click:InvokeServer({enemyGuid=tostring(spawnId),enemyPos=pos}) end)
    pcall(function() RE_Atk:FireServer({attackEnemyGUID=tostring(spawnId)}) end)
    pcall(function() RE_Atk:FireServer(tostring(spawnId)) end)
    if enemyId then pcall(function() RE_Click:InvokeServer({enemyGuid=tostring(enemyId),enemyPos=pos}) end) end
    for _, hGuid in ipairs(HERO_GUIDS) do
        pcall(function() RE_HeroSkill:FireServer({heroGuid=hGuid,enemyGuid=tostring(spawnId),skillType=1,masterId=MY_USER_ID}) end)
        pcall(function() RE_HeroSkill:FireServer({heroGuid=hGuid,enemyGuid=tostring(spawnId),skillType=2,masterId=MY_USER_ID}) end)
        pcall(function() RE_HeroSkill:FireServer({heroGuid=hGuid,enemyGuid=tostring(spawnId),skillType=3,masterId=MY_USER_ID}) end)
        pcall(function() RE_HeroStand:FireServer({masterId=MY_USER_ID,cframe=CFrame.new(pos+Vector3.new(2,0,2)),guid=hGuid}) end)
    end
end

local function AR_SetStatus(msg)
    AR.curStatus = msg
    if AR_statusCb then AR_statusCb() end
end

local function AutoRaidLoop()
    while AR.running do
        local mapIds = AR_GetMapIdsForMode()

        -- ── STEP 1: Cari portal raid yang aktif ──
        local foundMapId = nil
        local portalPos  = nil
        local waitSec    = 0

        AR_SetStatus("Menunggu event raid...")
        while AR.running do
            -- Cek semua map yang diizinkan, cari yang punya portal aktif
            for _, mid in ipairs(mapIds) do
                local pos = AR_GetPortalPos(mid)
                if pos then foundMapId=mid; portalPos=pos; break end
            end
            if foundMapId then break end
            waitSec = waitSec + 1
            AR_SetStatus("Menunggu raid... ("..waitSec.."s)")
            task.wait(1)
        end
        if not AR.running then break end

        local rankName = AR_GetRankName(foundMapId)
        AR.curMap = foundMapId

        -- ── STEP 2: Teleport ke portal ──
        AR_SetStatus("Masuk portal Map "..foundMapId.." | "..rankName)
        local char = LP.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(portalPos + Vector3.new(0,3,0)) end

        -- Tunggu raid room load
        for i=AR.waitBoss, 1, -1 do
            if not AR.running then break end
            AR_SetStatus("Masuk Map "..foundMapId.." | "..rankName.." | Loading "..i.."s...")
            task.wait(1)
        end
        if not AR.running then break end

        -- ── STEP 3: Attack boss + musuh ──
        AR_SetStatus("Menyerang boss | Map "..foundMapId.." | "..rankName)
        local bossTimer = 0
        local maxBoss   = 90
        local gotReward = false

        while AR.running and bossTimer < maxBoss do
            local bossParts = AR_GetBossParts()
            if #bossParts == 0 then break end  -- boss mati

            local bp = bossParts[1]
            char = LP.Character; hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(bp.Position + Vector3.new(0,3,3)) end

            for _, bossPart in ipairs(bossParts) do
                local sid=bossPart:GetAttribute("SpawnId"); local eid=bossPart:GetAttribute("EnemyId")
                if sid then AR_FireDmg(sid, eid, bossPart.Position) end
            end
            for _, e in ipairs(AR_GetRaidEnemies()) do
                AR_FireDmg(e.spawnId, e.enemyId, e.part.Position)
            end
            task.wait(0.1); bossTimer = bossTimer + 0.1
        end

        -- ── STEP 4: Collect reward ──
        AR_SetStatus("Mengambil reward | Map "..foundMapId)
        local colF = workspace:FindFirstChild("Collects")
        local rewardCount = 0
        if colF then
            for _, item in ipairs(colF:GetChildren()) do
                local ig = item:GetAttribute("Guid") or item:GetAttribute("ItemGuid")
                if ig then
                    pcall(function() RE_Col:FireServer({itemGuid=ig}) end)
                    rewardCount = rewardCount + 1
                end
            end
        end
        -- Hitung sebagai completed HANYA jika dapat reward
        if rewardCount > 0 then
            gotReward = true
            AR.completed = AR.completed + 1
        end
        task.wait(1)

        -- ── STEP 5: Cooldown ──
        local resultMsg = gotReward
            and ("✅ Raid selesai! Map "..foundMapId.." | "..rankName.." | Reward: "..rewardCount)
            or  ("⚠ Raid selesai tanpa reward | Map "..foundMapId)

        for i=AR.cooldown, 1, -1 do
            if not AR.running then break end
            AR_SetStatus(resultMsg.."\nDelay masuk raid lagi: "..i.."s")
            task.wait(1)
        end
        AR.curMap = nil
    end
    AR_SetStatus("Waiting Raids...")
    AR.curMap = nil
end

