-- Fire semua damage — karakter + semua hero/pet brutal
-- Hero guid di-capture otomatis dari hookmetamethod.
local function FireAllDamage(g, ep)
    -- ── Karakter utama ──────────────────────────────
    pcall(function() RE_Click:InvokeServer({enemyGuid=g, enemyPos=ep}) end)
    pcall(function() RE_Atk:FireServer({attackEnemyGUID=g}) end)
    pcall(function() RE_Atk:FireServer(g) end)

    -- ── Hero / Pet brutal ───────────────────────────
    -- HERO_GUIDS diisi otomatis saat game mengirim HeroMoveToEnemyPos
    -- (terjadi saat kamu klik musuh manual pertama kali setelah load)
    for _, hGuid in ipairs(HERO_GUIDS) do
        -- Spam skillType 1, 2, 3 sekaligus per hero
        -- skillType=1 basic, =2 skill, =3 ultimate/angry
        pcall(function() RE_HeroSkill:FireServer({heroGuid=hGuid, enemyGuid=g, skillType=1, masterId=MY_USER_ID}) end)
        pcall(function() RE_HeroSkill:FireServer({heroGuid=hGuid, enemyGuid=g, skillType=2, masterId=MY_USER_ID}) end)
        pcall(function() RE_HeroSkill:FireServer({heroGuid=hGuid, enemyGuid=g, skillType=3, masterId=MY_USER_ID}) end)
        pcall(function() RE_HeroStand:FireServer({masterId=MY_USER_ID, cframe=CFrame.new(ep+Vector3.new(2,0,2)), guid=hGuid}) end)
    end
end

-- Kirim HeroMoveToEnemyPos sekali saat teleport ke musuh baru
local function FireHeroMoveToTarget(enemyGuid, enemyPos)
    if #HERO_GUIDS == 0 then return end
    local posInfos = {}
    for i, hGuid in ipairs(HERO_GUIDS) do
        local offset = Vector3.new((i-1)*3 - 3, 0, (i%2==0 and 2 or -2))
        posInfos[hGuid] = enemyPos + offset
    end
    pcall(function()
        RE_HeroMove:FireServer({
            attackTarget      = enemyGuid,
            userId            = MY_USER_ID,
            heroTagetPosInfos = posInfos,
        })
    end)
end

local function AttackLoop_Goyang(onStatus)
    colG={}; dstQ={}
    SaveOrigin()

    while AG.running do
        local tgt = AG.currentTarget

        -- Belum ada target dipilih → standby
        if not tgt then
            if onStatus then onStatus("👆 Tap nama musuh di Enemy List...") end
            task.wait(0.2); continue
        end

        -- Target mati / hilang dari map
        if IsDead(tgt) or not tgt.model.Parent then
            if onStatus then onStatus("💀 ["..tgt.model.Name.."] mati — tap musuh lain") end
            ReturnHRPToOrigin(); task.wait(0.3); continue
        end

        local tHrp = tgt.model:FindFirstChild("HumanoidRootPart")
        if not tHrp then task.wait(0.1); continue end

        local g = tgt.guid
        local snapPos = tHrp.Position

        -- Teleport SEKALI ke dekat musuh
        TeleportHRPToEnemy(snapPos)
        -- Beritahu server hero bergerak ke musuh ini (sekali saja)
        FireHeroMoveToTarget(g, snapPos)
        if onStatus then onStatus("🕺 Goyang → ["..tgt.model.Name.."]  💎"..AG.collected) end

        -- Attack loop di tempat sampai:
        -- · target mati, ATAU
        -- · user mengganti target (AG.currentTarget berubah)
        local activeTgt = tgt
        while AG.running do
            -- Cek switch target oleh user
            if AG.currentTarget ~= activeTgt then break end
            -- Cek target mati
            if IsDead(activeTgt) or not activeTgt.model.Parent then
                ReturnHRPToOrigin()
                if onStatus then onStatus("💀 ["..activeTgt.model.Name.."] mati — tap musuh lain") end
                break
            end
            FireAllDamage(g, snapPos)
            task.wait()
        end
    end

    ReturnHRPToOrigin()
    return false
end

-- =====================================================
-- LOOP RUNNER - Mass Attack (pakai map rotation)
-- =====================================================
local function RunLoop(state, cfg, loopFn, onStatus, onDone)
    state.running=true; state.killed=0; state.collected=0
    StartDestroyWorker(function() return state.running end)
    state.thread=task.spawn(function()
        local last=0
        while state.running do
            local sel={}; for i=1,#MAPS do if cfg.selected[i] then table.insert(sel,i) end end
            if #sel>0 then
                local ni=nil; for _,i in ipairs(sel) do if i>last then ni=i; break end end
                if not ni then ni=sel[1]; last=0 end; last=ni
                local m=MAPS[ni]; if onStatus then onStatus("🗺 → "..m.name) end
                TpMap(m)
                local d=0; while d<cfg.teleportDelay and state.running do task.wait(0.2); d=d+0.2 end
                if not state.running then break end
                if not loopFn(onStatus) then break end
                if onStatus then onStatus("✅ "..cfg.nextMapDelay.."s...") end
                d=0; while d<cfg.nextMapDelay and state.running do task.wait(0.2); d=d+0.2 end
            else
                last=0
                local done=loopFn(onStatus)
                if done and state.running then
                    if onStatus then onStatus("✅ Loop "..cfg.nextMapDelay.."s...") end
                    local d=0; while d<cfg.nextMapDelay and state.running do task.wait(0.2); d=d+0.2 end
                end
            end
        end
        state.running=false; if onDone then onDone() end
    end)
end

-- =====================================================
-- AG RUNNER — langsung attack di map saat ini (tanpa rotation)
-- =====================================================
local function RunAG(onStatus, onDone)
    AG.running=true; AG.killed=0; AG.collected=0
    StartDestroyWorker(function() return AG.running end)
    AG.thread=task.spawn(function()
        -- Loop terus di map sekarang, serang musuh dari target list
        while AG.running do
            local done = AttackLoop_Goyang(onStatus)
            if not AG.running then break end
            -- Semua target habis / map kosong → tunggu sebentar lalu coba lagi
            if done then
                if onStatus then onStatus("✅ Semua target habis, nunggu spawn...") end
                task.wait(1)
            end
        end
        AG.running=false; if onDone then onDone() end
    end)
end

local function StopLoop(state, extraFn)
    state.running=false
    if state.thread then pcall(function() task.cancel(state.thread) end); state.thread=nil end
    if extraFn then extraFn() end
end

