-- ── ATTACK SAMPAI KILL TARGET TERCAPAI ────────────────
local function AttackUntilKillTarget(onStatus)
    -- JANGAN reset deadGuids global — dipakai EnemyDeath event listener
    -- Hanya bersihkan queue collect & destroyer untuk sesi map ini
    collectedGuids = {}
    destroyerQueue = {}

    -- Snapshot GUID yang sudah mati SEBELUM sesi ini
    -- sehingga kill lama tidak dihitung sebagai kill baru
    local guidsBefore = {}
    for guid, _ in pairs(deadGuids) do
        guidsBefore[guid] = true
    end

    -- Kill counter khusus sesi ini (tidak bergantung MassAttack.killed global)
    local killsThisSession = 0
    local sessionConn = RE_EnemyDeath.OnClientEvent:Connect(function(data)
        if not data then return end
        local guid = data.enemyGuid or data.guid
        if guid and not guidsBefore[guid] then
            guidsBefore[guid] = true   -- tandai agar tidak double-count
            killsThisSession = killsThisSession + 1
        end
    end)

    -- Tunggu musuh pertama muncul (max 6 detik)
    local waitT = 0
    while waitT < 6 and MassAttack.running do
        if #GetEnemies() > 0 then break end
        if onStatus then
            onStatus("⚠ Tidak ada musuh... ("..math.floor(6-waitT).."s)", true)
        end
        task.wait(0.4); waitT = waitT + 0.4
    end
    if not MassAttack.running then
        pcall(function() sessionConn:Disconnect() end)
        return false
    end

    -- Jika setelah tunggu masih kosong → skip map ini
    if #GetEnemies() == 0 then
        pcall(function() sessionConn:Disconnect() end)
        if onStatus then onStatus("⏭ Map kosong, skip ke map berikutnya", false) end
        return true
    end

    -- Untuk Kill All: konfirmasi area kosong selama 1.5 detik berturut-turut
    local CONFIRM_EMPTY_TIME = 1.5
    local emptyAccum         = 0

    while MassAttack.running do
        local target    = MassAttack.killTarget
        local isKillAll = (target == 0)

        local alive = 0
        for _, e in ipairs(GetEnemies()) do
            if not IsEnemyDead(e) then alive = alive + 1 end
        end

        if isKillAll then
            if alive == 0 then
                emptyAccum = emptyAccum + 0.08
                if emptyAccum >= CONFIRM_EMPTY_TIME then
                    pcall(function() sessionConn:Disconnect() end)
                    return true
                end
                task.wait(0.08)
                continue
            else
                emptyAccum = 0
            end
            if onStatus then
                onStatus("⚔ Kill All: "..alive.." sisa  💎 "..MassAttack.collected, true)
            end
        else
            emptyAccum = 0
            if killsThisSession >= target then
                pcall(function() sessionConn:Disconnect() end)
                task.wait(0.05)
                return true
            end
            if onStatus then
                onStatus("⚔ "..alive.." hidup  🎯 "..killsThisSession.."/"..target.."  💎 "..MassAttack.collected, true)
            end
        end

        for _, e in ipairs(GetEnemies()) do
            if not IsEnemyDead(e) then
                local hrp = e.model and e.model:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local enemyGuid = e.guid
                    local enemyPos  = hrp.Position
                    task.spawn(function()
                        pcall(function()
                            RE_Click:InvokeServer({ enemyGuid = enemyGuid, enemyPos = enemyPos })
                        end)
                        pcall(function()
                            RE_Attack:FireServer({ attackEnemyGUID = enemyGuid })
                        end)
                    end)
                end
            end
        end

        task.wait(0.08)
    end

    pcall(function() sessionConn:Disconnect() end)
    return false
end

