-- ── ANTI AFK ─────────────────────────────────────────
-- Cara kerja: setiap 60 detik gerakkan karakter micro-movement
-- (jump sangat kecil via VirtualUser) agar game tidak deteksi AFK.
-- Juga pantau popup "Reconnect?" yang biasanya muncul saat AFK
-- dan langsung klik tombol dismiss-nya.

local VirtualUser = game:GetService("VirtualUser")
local PlayerSettings_afk = false
local afkThread = nil

local function StartAntiAFK()
    if afkThread then return end
    PlayerSettings_afk = true
    afkThread = task.spawn(function()
        while PlayerSettings_afk do
            -- Simulasi input agar server tidak deteksi idle
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(0, 0))
            end)
            task.wait(15)
        end
        afkThread = nil
    end)
end

local function StopAntiAFK()
    PlayerSettings_afk = false
    if afkThread then
        pcall(function() task.cancel(afkThread) end)
        afkThread = nil
    end
end

