-- ── AUTO HIDE REWARD NOTIF ────────────────────────────
-- Strategi GANDA (berlapis):
-- 1. Event: pantau TipsPanel.RewardFrame → Destroy() saat muncul
-- 2. Polling: setiap 0.3 detik, jika RewardFrame masih ada →
--    klik semua sudut layar via VirtualInputManager agar popup tutup
--    (sama persis seperti "Click anywhere to close this window")
local notifThread = nil
local notifConn1  = nil
local notifConn2  = nil

local VIM_notif = game:GetService("VirtualInputManager")

local function ClickAllCorners()
    -- Klik di beberapa titik layar: tengah, sudut-sudut, tepi
    local vp = workspace.CurrentCamera.ViewportSize
    local pts = {
        Vector2.new(vp.X * 0.5,  vp.Y * 0.5),   -- tengah
        Vector2.new(vp.X * 0.1,  vp.Y * 0.1),   -- kiri atas
        Vector2.new(vp.X * 0.9,  vp.Y * 0.1),   -- kanan atas
        Vector2.new(vp.X * 0.1,  vp.Y * 0.9),   -- kiri bawah
        Vector2.new(vp.X * 0.9,  vp.Y * 0.9),   -- kanan bawah
        Vector2.new(vp.X * 0.5,  vp.Y * 0.85),  -- bawah tengah (area Confirm)
        Vector2.new(vp.X * 0.5,  vp.Y * 0.2),   -- atas tengah
    }
    for _, pt in ipairs(pts) do
        pcall(function()
            VIM_notif:SendMouseButtonEvent(pt.X, pt.Y, 0, true,  game, 1)
            VIM_notif:SendMouseButtonEvent(pt.X, pt.Y, 0, false, game, 1)
        end)
    end
end

local function TryDestroyRewardFrame()
    local destroyed = false
    pcall(function()
        local tips = LocalPlayer.PlayerGui:FindFirstChild("TipsPanel")
        if not tips then return end
        local rf = tips:FindFirstChild("RewardFrame")
        if rf then
            rf:Destroy()
            destroyed = true
        end
    end)
    return destroyed
end

local function StartHideNotif()
    -- Bersihkan state lama
    if notifConn1 then pcall(function() notifConn1:Disconnect() end) notifConn1 = nil end
    if notifConn2 then pcall(function() notifConn2:Disconnect() end) notifConn2 = nil end
    if notifThread then pcall(function() task.cancel(notifThread) end) notifThread = nil end

    -- Coba destroy yang sudah ada sekarang
    TryDestroyRewardFrame()

    -- LAYER 1: Event listener → destroy RewardFrame saat muncul
    local function WatchTipsPanel(tipsPanel)
        if notifConn2 then pcall(function() notifConn2:Disconnect() end) end
        notifConn2 = tipsPanel.ChildAdded:Connect(function(child)
            if not PlayerSettings.hideNotif then return end
            if child.Name == "RewardFrame" then
                task.defer(function()
                    pcall(function() child:Destroy() end)
                end)
            end
        end)
        -- Destroy yang sudah ada di TipsPanel ini
        pcall(function()
            local rf = tipsPanel:FindFirstChild("RewardFrame")
            if rf then rf:Destroy() end
        end)
    end

    local tips = LocalPlayer.PlayerGui:FindFirstChild("TipsPanel")
    if tips then WatchTipsPanel(tips) end

    notifConn1 = LocalPlayer.PlayerGui.ChildAdded:Connect(function(child)
        if not PlayerSettings.hideNotif then return end
        if child.Name == "TipsPanel" then
            task.defer(function()
                if PlayerSettings.hideNotif then WatchTipsPanel(child) end
            end)
        end
    end)

    -- LAYER 2: Polling setiap 0.3 detik
    -- Jika RewardFrame masih ada (event terlambat/gagal) → klik semua sudut
    notifThread = task.spawn(function()
        while PlayerSettings.hideNotif do
            local tips2 = LocalPlayer.PlayerGui:FindFirstChild("TipsPanel")
            if tips2 and tips2:FindFirstChild("RewardFrame") then
                -- Ada popup → coba destroy dulu, lalu klik layar
                TryDestroyRewardFrame()
                ClickAllCorners()
            end
            task.wait(0.3)
        end
        notifThread = nil
    end)
end

local function StopHideNotif()
    PlayerSettings.hideNotif = false
    if notifConn1 then pcall(function() notifConn1:Disconnect() end) notifConn1 = nil end
    if notifConn2 then pcall(function() notifConn2:Disconnect() end) notifConn2 = nil end
    if notifThread then pcall(function() task.cancel(notifThread) end) notifThread = nil end
end

